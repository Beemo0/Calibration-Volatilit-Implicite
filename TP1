#On met ici toutes les fonctions utiles à la suite du TP
def BlackScholes_Call(S, K, T, t, r, sigma):
    d1 = (np.log(S / K) + (r + 0.5 * sigma**2) * (T-t)) / (sigma * np.sqrt(T-t))
    d2 = d1 - sigma * np.sqrt(T - t)
    call_price = S * norm.cdf(d1) - K * np.exp(-r * (T-t)) * norm.cdf(d2)
    return call_price


def BlackScholes_Put(S, K, T, t, r, sigma):
    put_price = BlackScholes_Call(S, K, T, t, r, sigma)- S + K * np.exp(-r * (T-t))
    return put_price

def Vega(S, K, T, t, r, sigma):
    d1 = (np.log(S / K) + (r + 0.5 * sigma**2) * (T-t)) / (sigma * np.sqrt(T-t))
    vega = S * norm.pdf(d1) * np.sqrt(T-t)
    return vega

#Algorithme de Newton
def Newton(S,K,r,sigma,T,t,M,g):
    while abs((F(S,K,r,sigma,T,t,M))) > g:
        sigma = sigma - F(S,K,r,sigma,T,t,M)/Vega(S, K, T, t, r, sigma)
    return sigma

def F(S,K,r,sigma,T,t,M):
    return BlackScholes_Call(S, K, T, t, r, sigma) - M

def F_Put(S, K, r, sigma, T, t, M):
    return BlackScholes_Put(S, K, T, t, r, sigma) - M

