def data_extract2():
    eps = 0.0001
    t = 0
    q = 0.0
    S0 = 3932.69
    chemin = "/home/cytech/Desktop/Documents/ING3/Calibration/TP1/NEW_spx_quotedata.csv"
    format = '%y-%m-%d'

    # Lecture du fichier
    fichier = pd.read_csv(chemin, header=0, sep=',')
    N = len(fichier)

    # Initialisation
    S_0 = np.full(N, S0)
    vol_imp = np.zeros(N)
    K = fichier['Strike'].values
    T = np.zeros(N)
    r = np.full(N, 0.05)
    Call = ((fichier['Bid'] + fichier['Ask']) / 2).values
    Put = ((fichier['Bid.1'] + fichier['Ask.1']) / 2).values
    Maturite = [datetime.strptime(d, format) for d in fichier['Expiration Date']]
    date_ref = Maturite[0]

    # Calcul des maturités et de la volatilité implicite
    for i in range(N):
        diff = (Maturite[i] - date_ref).days
        T[i] = diff / 365.25
        if T[i] <= 0:
            vol_imp[i] = 0
            continue
        if verification(Call[i], S_0[i], K[i], T[i], t, r[i]):
            try:
                #Initialisation du sigma
                sigma = [np.sqrt(2 * abs((np.log(S_0[i] / K[i]) + r[i] * T[i]) / T[i]))]
                #Algorithme de Newton
                for _ in range(50):  # J'ai instauré une limite de sécurité sur les itérations
                    f_val = F(S_0[i], K[i], r[i], sigma[-1], T[i], t, Call[i])
                    vega_val = Vega(S_0[i], K[i], T[i], t, r[i], sigma[-1])
                    if vega_val == 0 or np.isnan(vega_val) or np.isinf(vega_val):
                        break
                    sigma_new = sigma[-1] - f_val / vega_val
                    if np.isnan(sigma_new) or np.isinf(sigma_new):
                        break
                    sigma.append(sigma_new)
                    if abs(f_val) < eps:
                        break
                vol_imp[i] = sigma[-1]
            except Exception:
                vol_imp[i] = 0
        else:
            vol_imp[i] = 0

    # Suppression des lignes avec volatilité nulle
    valid = (vol_imp > 0) & (~np.isnan(vol_imp)) & (~np.isinf(vol_imp))
    K = K[valid]
    T = T[valid]
    vol_imp = vol_imp[valid]
    Call = Call[valid]
    Put = Put[valid]
    r = r[valid]

    # Plot smile 2D
    plt.figure()
    plt.plot(K, vol_imp, ".")
    plt.title("Smile de volatilité implicite")
    plt.xlabel("Strike (K)")
    plt.ylabel("Volatilité implicite")
    plt.grid(True)
    plt.show()

    # Découpage de sous ensemble dans une liste
    T_unique = sorted(set(T))
    S_hat = []

    # Estimation de S par la parité Call - Put
    for Tj in T_unique:
        indices = np.where(T == Tj)[0]
        if len(indices) > 0:
            s_vals = Call[indices] - Put[indices] + np.exp(-r[indices] * T[indices]) * K[indices]
            s_moy = np.mean(s_vals)
            if s_moy > 0:
                S_hat.append(s_moy)
            else:
                S_hat.append(np.nan)
        else:
            S_hat.append(np.nan)

    S_hat = np.array(S_hat)
    valid_ln = ~np.isnan(S_hat) & (S_hat > 0)
    ln_S = np.log(S_hat[valid_ln])
    T_arr = np.array(T_unique)[valid_ln].reshape(-1, 1)

    # On fait une régression linéaire sur : ln(S) = β1*​T+ β2
    # pour vérifier nos calculs et on plot le résultat
    model = LinearRegression()
    model.fit(T_arr, ln_S)

    # β1 ​= −q
    # β2​ = ln(S0​)
    beta1 = model.coef_[0]
    beta2 = model.intercept_
    print(f"β1 = {beta1:.6f}, β2 = {beta2:.6f}")

    # Plot regression linéaire
    plt.figure()
    plt.scatter(T_arr, ln_S, color='blue', label='Données observées')
    plt.plot(T_arr, model.predict(T_arr), color='red', label='Régression linéaire')
    plt.xlabel("Maturité T")
    plt.ylabel("ln(S chapeau)")
    plt.title("Régression linéaire de ln(S chapeau)")
    plt.legend()
    plt.grid(True)
    plt.show()

    # Plot smile 3D
    fig = plt.figure()
    ax = fig.add_subplot(111, projection='3d')
    ax.scatter(K, T, vol_imp, c='blue', marker='o')
    ax.set_title("Smile 3D - Volatilité implicite")
    ax.set_xlabel("Strike (K)")
    ax.set_ylabel("Maturité (T)")
    ax.set_zlabel("Vol. implicite")
    plt.show()

