# Fonction de vérification pour le Call
def verification(Call, S, K, T, t, r):
    if max(S - K * np.exp(-r * (T-t)), 0) < Call < S:
        return 1
    return 0

# Fonction de vérification du Put
def verification2(Put, S, K, T, t, r):
    if max(S - K * np.exp(-r * (T-t)),0) - S + K*np.exp(-r*(T-t)) < Put < K * np.exp(-r*(T-t)):
        return 1
    return 0

